{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ollama-ai/chat",
	"version": "1.0.0",
	"title": "Ollama AI Chat",
	"category": "widgets",
	"icon": "format-chat",
	"description": "Embed an AI chat powered by Ollama.",
	"keywords": [ "chat", "ai", "ollama" ],
	"textdomain": "ollama-ai-chat",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"height": {
			"type": "string",
			"default": "500px"
		},
		"theme": {
			"type": "string",
			"default": "auto",
			"enum": [ "light", "dark", "auto" ]
		},
		"modelOverride": {
			"type": "string",
			"default": ""
		},
		"layout": {
			"type": "string",
			"default": "inline",
			"enum": [ "widget", "inline" ]
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	}
}
