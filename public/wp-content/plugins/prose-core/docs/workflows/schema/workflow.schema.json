{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://courtflow.ai/schemas/workflow.schema.json",
  "title": "CourtFlow Workflow Definition",
  "description": "Standardized workflow definition for NYC Supreme Court and Family Court matters.",
  "type": "object",
  "required": [
    "workflow",
    "workflow_category",
    "issue_type",
    "court",
    "counties_supported",
    "description",
    "triggers",
    "entry_questions",
    "routing_rules",
    "routing_priority",
    "intake_priority",
    "entry_conditions",
    "required_fields",
    "stages",
    "workflow_outcomes",
    "required_forms",
    "optional_forms",
    "supporting_documents"
  ],
  "additionalProperties": false,
  "properties": {
    "workflow": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "workflow_category": {
      "type": "string",
      "enum": ["divorce", "family_court"]
    },
    "issue_type": {
      "type": "string"
    },
    "court": {
      "type": "string",
      "enum": ["supreme_court", "family_court"]
    },
    "counties_supported": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["New York", "Kings", "Queens", "Bronx", "Richmond"]
      },
      "minItems": 1
    },
    "description": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "entry_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "routing_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "workflow"],
        "additionalProperties": false,
        "properties": {
          "condition": { "type": "string", "minLength": 1 },
          "workflow": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        }
      }
    },
    "routing_priority": {
      "type": "integer",
      "minimum": 0
    },
    "intake_priority": {
      "type": "integer",
      "minimum": 0
    },
    "entry_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "type", "required", "question"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "type": {
            "type": "string",
            "enum": ["string", "integer", "boolean", "date", "array"]
          },
          "required": { "type": "boolean" },
          "question": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "workflow_outcomes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "required_forms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "forms"],
        "additionalProperties": false,
        "properties": {
          "stage": { "type": "string" },
          "forms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code"],
              "additionalProperties": false,
              "properties": {
                "code": { "type": "string" },
                "internal_code": { "type": ["string", "null"] },
                "title": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "optional_forms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "forms"],
        "additionalProperties": false,
        "properties": {
          "stage": { "type": "string" },
          "forms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code"],
              "additionalProperties": false,
              "properties": {
                "code": { "type": "string" },
                "internal_code": { "type": ["string", "null"] },
                "title": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "supporting_documents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "includes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "internal": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "workflow_enum": { "type": "string" },
        "node_sequence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source_references": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    }
  }
}
