{
  "workflow": "default_divorce_nyc",
  "workflow_category": "divorce",
  "issue_type": "divorce",
  "court": "supreme_court",
  "counties_supported": [
    "New York",
    "Kings",
    "Queens",
    "Bronx",
    "Richmond"
  ],
  "description": "Default matrimonial action in NYC Supreme Court when the defendant does not answer after proper service.",
  "triggers": [
    "default divorce",
    "no answer",
    "defendant did not respond",
    "default judgment divorce",
    "never responded",
    "did not respond",
    "spouse never responded",
    "settlement agreement",
    "already filed divorce"
  ],
  "entry_questions": [
    "Has a divorce case already been started in a New York court?",
    "Was your spouse properly served with the divorce papers?",
    "Did your spouse fail to answer or appear within the required time?",
    "Do you have any children under 21?"
  ],
  "routing_rules": [
    {
      "condition": "spouse_responded=true",
      "workflow": "contested_divorce_nyc"
    },
    {
      "condition": "custody_dispute=true",
      "workflow": "contested_divorce_nyc"
    },
    {
      "condition": "support_dispute=true",
      "workflow": "contested_divorce_nyc"
    },
    {
      "condition": "domestic_violence_concerns=true",
      "workflow": "family_offense_nyc"
    }
  ],
  "routing_priority": 85,
  "intake_priority": 90,
  "entry_conditions": [
    "User seeks a divorce in NYC",
    "Defendant was properly served",
    "Defendant did not file an answer within the required time",
    "Plaintiff seeks a default judgment"
  ],
  "required_fields": [
    {
      "key": "existing_case",
      "type": "boolean",
      "required": false,
      "question": "Has a divorce case already been started in court?"
    },
    {
      "key": "case_status",
      "type": "string",
      "required": false,
      "enum": [
        "NOT_STARTED",
        "FILED",
        "SERVED",
        "DEFAULT_ELIGIBLE",
        "READY_FOR_FINAL_PAPERS",
        "UNDER_REVIEW",
        "JUDGMENT_SIGNED",
        "NOTICE_OF_ENTRY_FILED",
        "CLOSED"
      ],
      "question": "What is the current status of your divorce case?"
    },
    {
      "key": "county",
      "type": "string",
      "required": true,
      "question": "In which NYC county are you filing?"
    },
    {
      "key": "prior_court_cases",
      "type": "array",
      "required": false,
      "question": "Are there prior court cases involving you and your spouse?"
    },
    {
      "key": "domestic_violence_concerns",
      "type": "boolean",
      "required": false,
      "question": "Are there domestic violence or safety concerns?"
    },
    {
      "key": "support_dispute",
      "type": "boolean",
      "required": false,
      "question": "Is child or spousal support disputed?"
    },
    {
      "key": "custody_dispute",
      "type": "boolean",
      "required": false,
      "question": "Is custody disputed?"
    },
    {
      "key": "residency_qualification",
      "type": "string",
      "required": true,
      "question": "Which New York residency basis applies (1-year state, 2-year state, or other)?"
    },
    {
      "key": "marriage_location",
      "type": "string",
      "required": true,
      "question": "Where were you married? (NYC borough or city and state — e.g. Queens, NY)"
    },
    {
      "key": "marriage_date",
      "type": "date",
      "required": true,
      "question": "On what date were you married?"
    },
    {
      "key": "grounds_for_divorce",
      "type": "string",
      "required": true,
      "question": "What are your grounds for divorce?"
    },
    {
      "key": "plaintiff_information",
      "type": "string",
      "required": true,
      "question": "What is your full legal name and contact information?"
    },
    {
      "key": "defendant_information",
      "type": "string",
      "required": true,
      "question": "What is your spouse's full legal name and contact information?"
    },
    {
      "key": "service_date",
      "type": "date",
      "required": true,
      "question": "On what date was your spouse served?"
    },
    {
      "key": "has_minor_children",
      "type": "boolean",
      "required": true,
      "question": "Do you have any children under 21 with your spouse?"
    },
    {
      "key": "child_count",
      "type": "integer",
      "required": false,
      "question": "How many children are involved?"
    },
    {
      "key": "spouse_responded",
      "type": "boolean",
      "required": false,
      "question": "Has the defendant served or filed an Answer?"
    },
    {
      "key": "service_method",
      "type": "string",
      "required": false,
      "question": "How was the defendant served?"
    }
  ],
  "stages": [
    "commencement",
    "service",
    "default",
    "judgment"
  ],
  "workflow_outcomes": [
    "judgment_of_divorce"
  ],
  "required_forms": [
    {
      "stage": "commencement",
      "forms": [
        {
          "code": "UD-1",
          "internal_code": "UD-1",
          "title": "Summons With Notice",
          "required_when": "always"
        },
        {
          "code": "UD-2",
          "internal_code": "UD-2",
          "title": "Verified Complaint",
          "required_when": "always"
        }
      ]
    },
    {
      "stage": "service",
      "forms": [
        {
          "code": "UD-3",
          "internal_code": "UD-3",
          "title": "Affirmation of Service",
          "required_when": "always"
        }
      ]
    },
    {
      "stage": "default",
      "forms": [
        {
          "code": "UD-5",
          "internal_code": "UD-5",
          "title": "Affirmation of Regularity",
          "required_when": "always"
        },
        {
          "code": "UD-6",
          "internal_code": "UD-6",
          "title": "Sworn Affirmation of Plaintiff",
          "required_when": "always"
        }
      ]
    },
    {
      "stage": "judgment",
      "forms": [
        {
          "code": "UD-9",
          "internal_code": null,
          "title": "Note of Issue",
          "required_when": "final_papers_ready"
        },
        {
          "code": "UD-10",
          "internal_code": null,
          "title": "Findings of Fact and Conclusions of Law",
          "required_when": "always"
        },
        {
          "code": "UD-11",
          "internal_code": null,
          "title": "Judgment of Divorce",
          "required_when": "court_approves_package"
        },
        {
          "code": "UD-14",
          "internal_code": null,
          "title": "Notice of Entry",
          "required_when": "always"
        }
      ]
    }
  ],
  "optional_forms": [
    {
      "stage": "judgment",
      "forms": [
        {
          "code": "UD-8(3)",
          "internal_code": null,
          "title": "Child Support Worksheet",
          "required_when": "has_minor_children == true"
        }
      ]
    }
  ],
  "supporting_documents": [
    "marriage_certificate",
    "proof_of_service",
    "birth_certificates",
    "affidavit_of_regularity"
  ],
  "includes": [],
  "internal": {
    "workflow_enum": "DEFAULT_DIVORCE",
    "node_sequence": [
      "NODE_1001_DIVORCE_FILED",
      "NODE_1002_SERVICE_COMPLETE",
      "NODE_1010_JUDGMENT"
    ],
    "progression": [
      {
        "node": "NODE_1001_DIVORCE_FILED"
      },
      {
        "node": "NODE_1002_SERVICE_COMPLETE",
        "condition": {
          "kind": "event",
          "value": "SERVICE_COMPLETED"
        }
      },
      {
        "node": "NODE_1010_JUDGMENT",
        "condition": {
          "kind": "event",
          "value": "JUDGMENT_ENTERED"
        }
      }
    ],
    "case_status_node_map": {
      "NOT_STARTED": "NODE_1001_DIVORCE_FILED",
      "FILED": "NODE_1001_DIVORCE_FILED",
      "SERVED": "NODE_1002_SERVICE_COMPLETE",
      "DEFAULT_ELIGIBLE": "NODE_1002_SERVICE_COMPLETE",
      "READY_FOR_FINAL_PAPERS": "NODE_1010_JUDGMENT",
      "UNDER_REVIEW": "NODE_1010_JUDGMENT",
      "JUDGMENT_SIGNED": "NODE_1010_JUDGMENT",
      "NOTICE_OF_ENTRY_FILED": "NODE_1010_JUDGMENT",
      "CLOSED": "NODE_1010_JUDGMENT"
    }
  },
  "source_references": [
    "https://www.nycourts.gov/courthelp/family/divorceStarting.shtml",
    "https://www.nycourts.gov/divorce/",
    "https://www.nycourts.gov/LegacyPDFS/divorce/COMPOSITE-UNCONTESTED-DIVORCE-FORMS.pdf"
  ]
}
