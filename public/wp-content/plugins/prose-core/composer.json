{
	"name": "prose/prose-core",
	"description": "ProSe Core — CourtFlow AI workflow, intake, and forms engine.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"scripts": {
		"test": "phpunit -c phpunit.xml.dist",
		"test:ai-intake": "phpunit -c phpunit.xml.dist --testsuite ai-intake",
		"test:intake": "phpunit -c phpunit.xml.dist --testsuite intake",
		"test:routing": "phpunit -c phpunit.xml.dist --testsuite routing",
		"test:unit": "phpunit -c phpunit.xml.dist --testsuite unit",
		"test:procedural": "phpunit -c phpunit.xml.dist --testsuite procedural"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {}
	}
}
