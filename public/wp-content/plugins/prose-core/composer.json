{
    "name": "courtflow/prose-core",
    "description": "CourtFlow AI — procedural workflow engine for NY family court",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.2",
        "openai-php/client": "^0.10 || ^0.11 || ^0.12 || ^0.13 || ^0.14 || ^0.15 || ^0.16 || ^0.17 || ^0.18 || ^0.19",
        "symfony/http-client": "^6.4 || ^7.0",
        "nyholm/psr7": "^1.8",
        "woocommerce/action-scheduler": "^3.8",
        "mikehaertl/php-pdftk": "^0.13",
        "setasign/fpdi": "^2.6",
        "ramsey/uuid": "^4.7",
        "league/flysystem": "^3.29",
        "monolog/monolog": "^3.7",
        "vlucas/phpdotenv": "^5.6",
        "psr/container": "^2.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "wp-coding-standards/wpcs": "^3.1",
        "phpunit/phpunit": "^10.0 || ^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Prose\\Core\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Prose\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "test": "pest",
        "phpstan": "phpstan analyse",
        "phpcs": "phpcs",
        "phpcbf": "phpcbf"
    }
}
