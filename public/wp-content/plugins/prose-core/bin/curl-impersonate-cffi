#!/usr/bin/env bash
# Browser-impersonating curl shim for ProSe court form downloads.
#
# Accepts the curl-style arguments the ProSe importer passes (see
# Form_File_Manager::download_with_curl) and downloads the URL using curl_cffi,
# which impersonates a real Chrome TLS fingerprint to get past Cloudflare.
#
# The plugin treats any binary whose name contains "impersonate" as a
# curl-impersonate variant and invokes it as:
#   curl-impersonate-cffi -sS -L -f --max-time 120 -o <dest> <url>
#
# Wire it up with the prose_core_curl_binary filter (see the bundled mu-plugin).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PY="${SCRIPT_DIR}/.venv-curl-impersonate/bin/python"

if [ ! -x "${VENV_PY}" ]; then
  VENV_PY="$(command -v python3 || true)"
fi

if [ -z "${VENV_PY}" ]; then
  echo "python3 not found; run bin/setup-curl-impersonate.sh" >&2
  exit 2
fi

dest=""
url=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o|--output)
      dest="${2:-}"
      shift 2
      ;;
    --max-time|-A|--user-agent|-e|--referer|-H|--header|--connect-timeout)
      shift 2
      ;;
    --)
      shift
      ;;
    -*)
      shift
      ;;
    *)
      url="$1"
      shift
      ;;
  esac
done

if [ -z "${url}" ] || [ -z "${dest}" ]; then
  echo "missing url or destination" >&2
  exit 2
fi

exec "${VENV_PY}" "${SCRIPT_DIR}/curl_cffi_download.py" "${url}" "${dest}"
